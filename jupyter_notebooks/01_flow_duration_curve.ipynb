  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# 📊 Flow Duration Curve (FDC) Analysis\n",
    "\n",
    "This notebook demonstrates how to calculate and plot a Flow Duration Curve using streamflow data. An FDC shows the percentage of time that flow in a stream is likely to equal or exceed some specified value of interest. It is a critical tool for hydropower design, water allocation, and habitat assessment."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import numpy as np\n",
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "\n",
    "# Set a professional plotting style\n",
     plt.style.use("dark_background")
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 1. Generate Synthetic Daily Streamflow Data (10 years)\n",
    "# In a real project, you would load this via pd.read_csv('river_data.csv')\n",
    "np.random.seed(42)\n",
    "days = pd.date_range(start=\"2010-01-01\", end=\"2019-12-31\")\n",
    "base_flow = 15 + 5 * np.sin(np.linspace(0, 20 * np.pi, len(days)))\n",
    "storm_flow = np.random.exponential(scale=10, size=len(days))\n",
    "total_flow = base_flow + storm_flow\n",
    "\n",
    "df = pd.DataFrame({'Date': days, 'Discharge_m3s': total_flow})\n",
    "print(f\"✅ Successfully loaded {len(df)} days of streamflow data.\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 2. Calculate Exceedance Probability\n",
    "# Sort the data in descending order\n",
    "df_sorted = df.sort_values(by='Discharge_m3s', ascending=False).reset_index(drop=True)\n",
    "\n",
    "# Calculate the rank and exceedance probability using the Weibull formula: P = [m / (n + 1)] * 100\n",
    "df_sorted['Rank'] = df_sorted.index + 1\n",
    "df_sorted['Exceedance_Probability'] = (df_sorted['Rank'] / (len(df_sorted) + 1)) * 100\n",
    "\n",
    "df_sorted.head()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 3. Plot the Flow Duration Curve\n",
    "plt.figure(figsize=(10, 6))\n",
    "plt.plot(df_sorted['Exceedance_Probability'], df_sorted['Discharge_m3s'], color='#0055ff', lw=2.5)\n",
    "plt.fill_between(df_sorted['Exceedance_Probability'], df_sorted['Discharge_m3s'], color='#0055ff', alpha=0.1)\n",
    "\n",
    "plt.title('Flow Duration Curve (10-Year Simulation)', fontsize=16, fontweight='bold')\n",
    "plt.xlabel('Exceedance Probability (%)', fontsize=12)\n",
    "plt.ylabel('Discharge (m³/s)', fontsize=12)\n",
    "plt.xlim(0, 100)\n",
    "plt.ylim(bottom=0)\n",
    "\n",
    "# Add key reference lines for hydrology (Q10 and Q90)\n",
    "q10 = np.percentile(df_sorted['Discharge_m3s'], 90) # 10% exceedance \n",
    "q90 = np.percentile(df_sorted['Discharge_m3s'], 10) # 90% exceedance\n",
    "\n",
    "plt.axvline(x=10, color='red', linestyle='--', alpha=0.7, label=f'Q10 (High Flow): {q10:.1f} m³/s')\n",
    "plt.axvline(x=90, color='green', linestyle='--', alpha=0.7, label=f'Q90 (Base Flow): {q90:.1f} m³/s')\n",
    "\n",
    "plt.legend()\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  }
 ],
